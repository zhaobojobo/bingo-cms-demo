{
  "name": "bingo/wms",
  "description": "Bingo 網站管理系統",
  "authors": [
    {
      "name": "Harper",
      "email": "harper.bingo@gmail.com"
    }
  ],
  "require": {
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "gevman/inflector": "^1.0",
    "league/plates": "^3.4",
    "nikic/fast-route": "^1.3",
    "phpmailer/phpmailer": "^6.2",
    "phpoffice/phpspreadsheet": "^1.25",
    "pimple/pimple": "^3.3",
    "sqhlib/hanzi-convert": "^1.1",
    "steelywing/chinese": "^0.5.3",
    "voku/anti-xss": "^4.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Site\\": "app/",
      "Admin\\": "wms/app/"
    },
    "files": [
      "app/Functions.php"
    ]
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true,
    "platform": {
      "php": "7.4"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10"
  }
}
